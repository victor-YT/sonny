# Ollama model Sonny should use for chat responses.
OLLAMA_MODEL=qwen3:8b

# Ollama HTTP API base URL.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Picovoice Porcupine access key for wake-word detection.
PORCUPINE_ACCESS_KEY=replace-me

# faster-whisper HTTP service URL for speech-to-text.
FASTER_WHISPER_URL=http://127.0.0.1:8000

# Chatterbox HTTP service URL for text-to-speech.
CHATTERBOX_URL=http://127.0.0.1:8001

# Enable the full voice loop when set to 1 or true.
SONNY_VOICE_MODE=1

{
  "name": "sonny",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "pnpm run test:integration",
    "test:integration": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "build": "tsc && pnpm --dir console-web build && pnpm run build:assets",
    "build:assets": "node scripts/build-assets.cjs",
    "dev": "pnpm run dev:full",
    "dev:app": "pnpm run build && pnpm run start:electron",
    "dev:services": "./scripts/start-services.sh",
    "dev:full": "pnpm run build && bash ./scripts/start-full.sh",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "start:services": "./scripts/start-services.sh",
    "start:full": "bash ./scripts/start-full.sh",
    "start:electron": "electron dist/ui/electron-entry.js",
    "start:text": "node dist/index.js",
    "start": "pnpm run build && pnpm run start:electron",
    "voice:file": "pnpm run build && node dist/dev/voice-file.js",
    "voice:simulate": "pnpm run voice:file",
    "voice:latency": "pnpm run build && node dist/dev/voice-latency-benchmark.js",
    "voice:smoke": "pnpm run build && node dist/dev/voice-smoke.js",
    "voice:providers": "pnpm run build && node dist/dev/provider-status.js",
    "stt:sherpa:test": "pnpm run build && node dist/dev/sherpa-onnx-smoke.js",
    "stt:sherpa:model": "bash ./scripts/download-sherpa-onnx-model.sh",
    "stt:benchmark": "pnpm run build && node dist/dev/stt-benchmark.js",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "electron": "^34.5.8",
    "express": "^5.2.1",
    "jimp": "^1.6.0",
    "menubar": "^9.5.2",
    "node-notifier": "^10.0.1",
    "node-record-lpcm16": "^1.0.1",
    "sherpa-onnx-node": "^1.12.39"
  }
}

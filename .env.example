# Foreground realtime LLM served by OLMX's OpenAI-compatible API.
SONNY_FOREGROUND_LLM_PROVIDER=olmx-foreground
SONNY_FOREGROUND_MODEL=Qwen2.5-1.5B-Instruct-4bit
OLMX_MODEL=Qwen2.5-1.5B-Instruct-4bit
OLMX_BASE_URL=http://127.0.0.1:8000

# Background/fallback LLM served by Ollama.
SONNY_BACKGROUND_LLM_PROVIDER=ollama-background
SONNY_BACKGROUND_MODEL=qwen3:8b

# Ollama model Sonny should use when selected as foreground or background.
OLLAMA_MODEL=qwen3:8b

# Ollama HTTP API base URL.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Keep the Ollama model loaded between requests. Use -1 to keep it resident.
OLLAMA_KEEP_ALIVE=-1

# openWakeWord HTTP service URL for wake-word detection.
WAKE_WORD_URL=http://localhost:8002

# Picovoice Porcupine access key for wake-word detection.
# Leave as replace-me unless you are enabling wake word locally.
PORCUPINE_ACCESS_KEY=replace-me

# Comma-separated wake words accepted by Sonny's voice loop.
SONNY_WAKE_WORDS=hey jarvis,alexa

# faster-whisper HTTP service URL for speech-to-text.
# Set SONNY_STT_PROVIDER=faster-whisper to use this fallback provider.
FASTER_WHISPER_URL=http://127.0.0.1:8000

# Default realtime speech-to-text provider.
SONNY_STT_PROVIDER=sherpa-onnx
SHERPA_ONNX_MODEL_DIR=models/sherpa-onnx-streaming-paraformer-bilingual-zh-en
SHERPA_ONNX_ENCODER=encoder.int8.onnx
SHERPA_ONNX_DECODER=decoder.int8.onnx
SHERPA_ONNX_TOKENS=tokens.txt
SHERPA_ONNX_LANGUAGE=zh
SHERPA_ONNX_MODEL_TYPE=paraformer
SHERPA_ONNX_PROVIDER=cpu
SHERPA_ONNX_NUM_THREADS=2

# Chatterbox HTTP service URL for text-to-speech.
CHATTERBOX_URL=http://127.0.0.1:8001

# VAD HTTP service URL for live microphone end-of-turn detection.
VAD_URL=http://127.0.0.1:8003

# Enable the full voice loop when set to 1 or true.
SONNY_VOICE_MODE=0
